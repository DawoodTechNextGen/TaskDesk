# DawoodTech Training Management System - Git Ignore

# Composer
/vendor/
composer.lock

# Node
/node_modules/
package-lock.json

# Certificates (generated files)
/certificates/*.html
/certificates/*.pdf
!certificates/.gitkeep

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Environment files
.env
.env.local
.env.production

# Temporary files
*.tmp
*.cache
/temp/

# Database Backups (local only)
/backups/

# Windows-only scripts (not needed on Linux/cPanel)
run_backup.bat

# PHP debug/testing files
xdebug*.html
